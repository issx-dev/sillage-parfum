# Stripe - obtener en https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook - obtener ejecutando: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# URL base
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base de datos (Supabase, Neon, etc.) — requerida por lib/db.ts
DATABASE_URL=postgresql://user:password@host:5432/database

# Upstash Redis (rate limiter) — opcional; sin esto, el middleware cae a un
# fallback en memoria (no apto para producción multi-instancia)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
