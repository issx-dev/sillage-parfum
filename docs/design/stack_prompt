━━━━━━━━━━━━━━━━━━━━━━━━
Genera el store completo con:

interface CartItem {
  variantId: string
  productId: string
  slug: string
  name: string
  brand: string
  image: string
  size_ml: number
  price: number
  quantity: number
}

interface CartStore {
  items: CartItem[]
  addItem: (item: CartItem) => void        → si ya existe suma cantidad
  removeItem: (variantId: string) => void
  updateQuantity: (variantId: string, quantity: number) => void
  clearCart: () => void
  getTotal: () => number
  getItemCount: () => number
  getFreeShippingRemaining: () => number   → umbral 50€
}

Usar persist middleware de Zustand para localStorage.

